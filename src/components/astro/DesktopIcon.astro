---
interface Props {
  id: string;
  label: string;
  icon: string;
  top: string;
  left: string;
}

const { id, label, icon, top, left } = Astro.props;
---

<div
  class="desktop-icon"
  style={`top: ${top}; left: ${left};`}
  data-window-id={id}
  ondblclick={`window.dispatchEvent(new CustomEvent('open-window', { detail: { id: '${id}' } }))`}
>
  <div class="desktop-icon-image">{icon}</div>
  <span class="desktop-icon-label">{label}</span>
</div>

<style>
  .desktop-icon {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    width: auto;
    min-width: 80px;
    cursor: pointer;
    user-select: none;
    padding: 6px 4px;
    border-radius: 6px;
  }

  .desktop-icon:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  .desktop-icon:active {
    background: rgba(255, 255, 255, 0.2);
  }

  .desktop-icon-image {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 56px;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
  }

  .desktop-icon-label {
    font-size: 12px;
    font-weight: 500;
    color: white;
    text-align: center;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
    white-space: nowrap;
    line-height: 1.3;
    font-family: var(--font-system);
    padding: 1px 4px;
    border-radius: 3px;
  }

  .desktop-icon:hover .desktop-icon-label,
  .desktop-icon:active .desktop-icon-label {
    background: rgba(0, 100, 255, 0.7);
  }

  /* Mobile: grid layout */
  @media (max-width: 768px) {
    .desktop-icon {
      position: static;
    }
  }
</style>
